# Copy to .env (which is gitignored) and fill in real values.
# These are read server-side by the Vite dev server (see vite.config.ts),
# so they're NEVER shipped to the browser bundle. For production on Amplify
# Hosting, set them instead as Amplify secrets:
#   npx ampx secret set BUILDIUM_CLIENT_ID --branch main
#   npx ampx secret set BUILDIUM_CLIENT_SECRET --branch main

BUILDIUM_CLIENT_ID=your-client-id-here
BUILDIUM_CLIENT_SECRET=your-client-secret-here
BUILDIUM_BASE_URL=https://api.buildium.com
